COURTVISION_ENVIRONMENT=development
COURTVISION_DATABASE_URL=postgresql+asyncpg://courtvision:courtvision@localhost:5432/courtvision
COURTVISION_REDIS_URL=redis://localhost:6379/0
COURTVISION_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
COURTVISION_INTERNAL_API_KEY=local-development-key
COURTVISION_ENABLE_DELAYED_LIVE=false
COURTVISION_PUBLIC_RATE_LIMIT_REQUESTS=120
COURTVISION_SHOT_QUALITY_RATE_LIMIT_REQUESTS=30
COURTVISION_RATE_LIMIT_WINDOW_SECONDS=60
COURTVISION_TRUST_PROXY_HEADERS=false
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
COURTVISION_INTERNAL_API_URL=http://localhost:8000
