COURTVISION_ENVIRONMENT=development
COURTVISION_DATABASE_URL=postgresql+asyncpg://courtvision:courtvision@localhost:5432/courtvision
COURTVISION_REDIS_URL=redis://localhost:6379/0
COURTVISION_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
COURTVISION_INTERNAL_API_KEY=local-development-key
COURTVISION_ENABLE_DELAYED_LIVE=false
COURTVISION_PUBLIC_RATE_LIMIT_REQUESTS=120
COURTVISION_SHOT_QUALITY_RATE_LIMIT_REQUESTS=30
COURTVISION_RATE_LIMIT_WINDOW_SECONDS=60
COURTVISION_TRUST_PROXY_HEADERS=false
# Optional managed local artifact directory. Use an absolute path shared by API
# and worker processes, or configure the S3-compatible backend below.
# COURTVISION_MODEL_ARTIFACT_LOCAL_ROOT=/var/lib/courtvision/models
# COURTVISION_MODEL_ARTIFACT_BACKEND=s3
# COURTVISION_MODEL_ARTIFACT_S3_BUCKET=courtvision-private-models
# COURTVISION_MODEL_ARTIFACT_S3_PREFIX=courtvision/models
# COURTVISION_MODEL_ARTIFACT_S3_REGION=us-east-1
# COURTVISION_MODEL_ARTIFACT_S3_ENDPOINT_URL=https://s3.example.com
# COURTVISION_MODEL_ARTIFACT_MAX_BYTES=104857600
# S3 credentials use the standard AWS_ACCESS_KEY_ID,
# AWS_SECRET_ACCESS_KEY, and optional AWS_SESSION_TOKEN variables.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
COURTVISION_INTERNAL_API_URL=http://localhost:8000
