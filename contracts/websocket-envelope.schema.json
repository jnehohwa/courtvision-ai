{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://courtvision.local/contracts/websocket-envelope.schema.json",
  "title": "CourtVision WebSocket Envelope",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "game_id",
    "sequence",
    "occurred_at",
    "ingested_at",
    "source_status",
    "model_version",
    "payload"
  ],
  "properties": {
    "type": {
      "enum": [
        "snapshot",
        "play_added",
        "play_corrected",
        "prediction_updated",
        "source_status",
        "heartbeat",
        "replay_completed"
      ]
    },
    "schema_version": { "const": "1.0" },
    "game_id": { "type": "string", "minLength": 1 },
    "sequence": { "type": "integer", "minimum": 0 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "ingested_at": { "type": "string", "format": "date-time" },
    "source_status": {
      "type": "string",
      "enum": ["replay", "delayed", "stale", "unavailable"]
    },
    "model_version": { "type": ["string", "null"] },
    "payload": { "type": "object" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": { "enum": ["play_added", "play_corrected"] }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/playPayload" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "enum": ["source_status", "heartbeat", "replay_completed"] }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/statusPayload" }
        }
      }
    }
  ],
  "additionalProperties": false,
  "$defs": {
    "playPayload": {
      "type": "object",
      "required": [
        "sequence",
        "source_event_id",
        "revision",
        "event_type",
        "description",
        "period",
        "clock_seconds",
        "home_score",
        "away_score",
        "possession_team_id",
        "home_fouls",
        "away_fouls",
        "x",
        "y",
        "shot_value",
        "home_probability"
      ],
      "properties": {
        "sequence": { "type": "integer", "minimum": 0 },
        "source_event_id": { "type": "string", "minLength": 1 },
        "revision": { "type": "integer", "minimum": 1 },
        "event_type": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "period": { "type": "integer", "minimum": 1, "maximum": 8 },
        "clock_seconds": { "type": "integer", "minimum": 0, "maximum": 720 },
        "home_score": { "type": "integer", "minimum": 0 },
        "away_score": { "type": "integer", "minimum": 0 },
        "possession_team_id": { "type": ["string", "null"] },
        "home_fouls": { "type": "integer", "minimum": 0 },
        "away_fouls": { "type": "integer", "minimum": 0 },
        "x": { "type": ["number", "null"] },
        "y": { "type": ["number", "null"] },
        "shot_value": { "enum": [2, 3, null] },
        "home_probability": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "statusPayload": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  }
}
